<view class="page">
  <view class="hero">
    <view class="hero-icon-wrap">
      <image class="icon-shield" src="/images/shield.png" mode="aspectFit" />
    </view>
    <text class="hero-title">隐私水印保护</text>
    <text class="hero-subtitle">为您的证件添加专属防盗用保护，守护信息安全。</text>
  </view>

  <view class="upload-panel">
    <view class="primary-action" bindtap="chooseFromAlbum">
      <view class="primary-icon-wrap">
        <view class="icon-image">
          <view class="icon-image-sun"></view>
          <view class="icon-image-mountain"></view>
        </view>
      </view>
      <text class="primary-title">从相册选择</text>
      <text class="primary-subtitle">选择已有照片添加专属水印</text>
    </view>

    <view class="secondary-action" bindtap="chooseFromCamera">
      <view class="secondary-icon-wrap">
        <view class="icon-camera">
          <view class="icon-camera-top"></view>
          <view class="icon-camera-lens"></view>
        </view>
      </view>
      <view class="secondary-text-wrap">
        <text class="secondary-title">拍照上传</text>
        <text class="secondary-subtitle">使用相机拍摄新照片</text>
      </view>
    </view>
  </view>

  <view class="advantage-section">
    <text class="advantage-label">核心优势</text>
    <view class="advantage-card">
      <view class="advantage-icon-wrap">
        <view class="icon-lock">
          <view class="icon-lock-top"></view>
          <view class="icon-lock-body"></view>
        </view>
      </view>
      <view class="advantage-text">
        <text class="advantage-title">数据绝对安全</text>
        <text class="advantage-desc">无服务器通信，所有图片与水印处理均在您的设备本地实时完成。</text>
      </view>
    </view>
  </view>
</view>
