.page {
  min-height: 100vh;
  padding: 96rpx 48rpx 80rpx;
  background: #f3f4f6;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 56rpx;
}

.hero-icon-wrap {
  width: 136rpx;
  height: 136rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ad46ff 0%, #9810fa 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 30rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 34rpx;
}

.icon-shield {
  width: 48rpx;
  height: 56rpx;
  border: 5rpx solid #fff;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  border-bottom-left-radius: 26rpx;
  border-bottom-right-radius: 26rpx;
  box-sizing: border-box;
}

.hero-title {
  display: block;
  font-size: 60rpx;
  font-weight: 700;
  color: #101828;
  line-height: 1.25;
  margin-bottom: 18rpx;
}

.hero-subtitle {
  display: block;
  font-size: 32rpx;
  line-height: 1.6;
  color: #6a7282;
}

.upload-panel {
  border: 2rpx solid #dab2ff;
  border-radius: 48rpx;
  padding: 40rpx;
  margin-bottom: 76rpx;
  background: linear-gradient(180deg, rgba(250, 245, 255, 0.5) 0%, rgba(0, 0, 0, 0) 100%);
}

.primary-action {
  border-radius: 40rpx;
  background: linear-gradient(145deg, #ad46ff 0%, #9810fa 100%);
  padding: 64rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.primary-icon-wrap {
  width: 124rpx;
  height: 124rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 34rpx;
}

.icon-image {
  width: 62rpx;
  height: 50rpx;
  border: 4rpx solid #fff;
  border-radius: 12rpx;
  position: relative;
  box-sizing: border-box;
}

.icon-image-sun {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fff;
  top: 8rpx;
  left: 8rpx;
}

.icon-image-mountain {
  position: absolute;
  width: 26rpx;
  height: 14rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
  left: 18rpx;
  top: 22rpx;
}

.primary-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.24;
  margin-bottom: 12rpx;
}

.primary-subtitle {
  display: block;
  font-size: 28rpx;
  color: #f3e8ff;
}

.secondary-action {
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 34rpx;
  padding: 34rpx 38rpx;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.secondary-icon-wrap {
  width: 110rpx;
  height: 110rpx;
  border-radius: 24rpx;
  background: #f3e8ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 26rpx;
  flex-shrink: 0;
}

.icon-camera {
  width: 54rpx;
  height: 36rpx;
  border: 4rpx solid #9810fa;
  border-radius: 10rpx;
  position: relative;
  box-sizing: border-box;
}

.icon-camera-top {
  position: absolute;
  width: 16rpx;
  height: 8rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #9810fa;
  top: -10rpx;
  left: 10rpx;
}

.icon-camera-lens {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 4rpx solid #9810fa;
  margin: 6rpx auto 0;
  box-sizing: border-box;
}

.secondary-text-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.secondary-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #101828;
  line-height: 1.2;
  margin-bottom: 6rpx;
}

.secondary-subtitle {
  font-size: 30rpx;
  color: #6a7282;
}

.upload-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #99a1af;
}

.advantage-section {
  width: 100%;
}

.advantage-label {
  display: block;
  font-size: 44rpx;
  line-height: 1.2;
  color: #4a5565;
  font-weight: 600;
  margin-bottom: 26rpx;
}

.advantage-card {
  border-radius: 28rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  padding: 34rpx;
  display: flex;
  align-items: flex-start;
}

.advantage-icon-wrap {
  width: 110rpx;
  height: 110rpx;
  border-radius: 24rpx;
  background: #f3e8ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-lock {
  width: 48rpx;
  height: 56rpx;
  position: relative;
}

.icon-lock-top {
  width: 28rpx;
  height: 20rpx;
  border: 4rpx solid #9810fa;
  border-bottom: 0;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  box-sizing: border-box;
  margin: 0 auto;
}

.icon-lock-body {
  width: 44rpx;
  height: 32rpx;
  border: 4rpx solid #9810fa;
  border-radius: 8rpx;
  box-sizing: border-box;
  margin: 2rpx auto 0;
}

.advantage-text {
  flex: 1;
}

.advantage-title {
  display: block;
  font-size: 46rpx;
  color: #101828;
  line-height: 1.2;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.advantage-desc {
  display: block;
  font-size: 30rpx;
  line-height: 1.6;
  color: #6a7282;
}
