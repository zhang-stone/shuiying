.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 80rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

/* 顶部信息卡片 */
.info-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.info-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.info-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.info-subtitle {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}

/* 选图区域 */
.pick-area {
  width: 100%;
  border: 4rpx dashed #7C4DFF;
  border-radius: 24rpx;
  padding: 60rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  background: rgba(124,77,255,0.03);
}

.pick-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(124,77,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.pick-icon {
  font-size: 56rpx;
}

.pick-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #7C4DFF;
  margin-bottom: 12rpx;
}

.pick-hint {
  font-size: 24rpx;
  color: #aaaaaa;
}

/* 核心优势 */
.advantage-section {
  width: 100%;
}

.advantage-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
  display: block;
}

.advantage-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advantage-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.advantage-icon {
  font-size: 48rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.advantage-text {
  display: flex;
  flex-direction: column;
}

.advantage-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.advantage-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}
