.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  box-sizing: border-box;
}

.preview-card {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  /* padding: 22rpx; */
  margin-bottom: 28rpx;
}

.canvas-stage {
  max-height: 80vh;
  min-height: 60vh;
  border-radius: 24rpx;
  overflow: hidden;
}

.canvas {
  width: 100%;
  max-height: 80vh;
  min-height: 60vh;
}

.content-box {
  padding: 22rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-last {
  margin-bottom: 8rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-icon {
  font-size: 28rpx;
  color: #475467;
  margin-right: 10rpx;
  line-height: 1;
}

.section-icon-emphasis {
  color: #ad46ff;
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
  color: #1e2939;
}

.text-input {
  width: 100%;
  height: 92rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 24rpx;
  padding: 0 24rpx;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}

.color-list {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-top: 2rpx;
}

.color-dot {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  box-sizing: border-box;
}

.color-dot.active {
  border-color: #ffffff !important;
  box-shadow: 0 0 0 4rpx #ad46ff;
}

.bottom-bar {
  width: 100%;
  background: #ffffff;
  padding: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  box-sizing: border-box;
}

.btn-save {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #ad46ff 0%, #9333ea 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-appearance: none;
}

.btn-save::after {
  border: 0;
}
