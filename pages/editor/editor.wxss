.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 预览区 */
.preview-area {
  flex-shrink: 0;
  height: 45vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8e8e8;
  position: relative;
}

.canvas-container {
  width: 100%;
  height: 100%;
  border-radius: 0;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}

.canvas {
  width: 100%;
  height: 100%;
}

/* 控制面板 */
.control-panel {
  flex: 1;
  height: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx 32rpx;
  overflow-y: auto;
}

/* 拖动指示条 */
.drag-indicator {
  width: 80rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin: 20rpx auto 28rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.label-prefix {
  color: #7C4DFF;
  font-weight: 700;
  margin-right: 4rpx;
}

/* 文字输入框 */
.text-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  color: #333333;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 颜色选择 */
.color-list {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  align-items: center;
  margin-top: 8rpx;
}

.color-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  transition: transform 0.1s;
}

.color-dot.active {
  transform: scale(1.2);
  box-shadow: 0 0 0 4rpx rgba(124,77,255,0.3);
}

/* 底部固定按钮区 */
.bottom-bar {
  flex-shrink: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #7C4DFF;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(124,77,255,0.4);
}
