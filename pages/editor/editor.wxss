.page {
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #f5f5f5;
}

.preview-shell {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 22rpx 22rpx calc(42vh + 22rpx);
  box-sizing: border-box;
}

.preview-card {
  width: 100%;
  height: 100%;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.canvas-stage {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
}

.canvas {
  width: 100%;
  height: 100%;
}

.control-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  background: #ffffff;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  box-shadow: 0 -12rpx 32rpx rgba(15, 23, 42, 0.12);
  display: flex;
  flex-direction: column;
  transition: height 220ms ease;
}

.control-sheet.dragging {
  transition: none;
}

.sheet-handle-wrap {
  width: 100%;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 12rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.sheet-handle {
  width: 108rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #98a2b3;
  box-shadow: 0 1rpx 2rpx rgba(15, 23, 42, 0.18);
}

.sheet-scroll {
  flex: 1;
  min-height: 0;
}

.content-box {
  padding: 20rpx 22rpx 0;
  box-sizing: border-box;
}

.section {
  margin-bottom: 30rpx;
}

.section-last {
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-icon {
  font-size: 28rpx;
  color: #475467;
  margin-right: 10rpx;
  line-height: 1;
}

.section-icon-emphasis {
  color: #ad46ff;
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
  color: #1e2939;
}

.text-input {
  width: 100%;
  height: 92rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 24rpx;
  padding: 0 24rpx;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}

.color-list {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-top: 2rpx;
}

.color-dot {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  box-sizing: border-box;
}

.color-dot.active {
  border-color: #ffffff !important;
  box-shadow: 0 0 0 4rpx #ad46ff;
}

.sheet-footer {
  padding: 20rpx 22rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  background: #ffffff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #ad46ff 0%, #9333ea 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-appearance: none;
}

.btn-save::after {
  border: 0;
}
